# ============================================================
# ENBICI — Variables de Entorno
# Copia este archivo como .env y completa los valores reales
# NUNCA commitear el archivo .env al repositorio
# ============================================================

# ========================
# SERVIDOR
# ========================
NODE_ENV=development
PORT=3000
API_VERSION=v1

# ========================
# BASE DE DATOS (PostgreSQL + PostGIS)
# ========================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=enbici_dev
DB_USER=enbici_user
DB_PASSWORD=tu_password_aqui
DB_SSL=false

# Producción (RDS AWS sa-east-1)
# DATABASE_URL=postgresql://user:pass@rds-endpoint.sa-east-1.rds.amazonaws.com:5432/enbici

# ========================
# REDIS (Cache + Pub/Sub WebSockets)
# ========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Producción (ElastiCache)
# REDIS_URL=redis://enbici.xxxxx.ng.0001.sae1.cache.amazonaws.com:6379

# ========================
# JWT (Autenticación)
# ========================
JWT_SECRET=cambia_esto_por_un_secreto_muy_largo_y_seguro_min_64_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ========================
# FIREBASE AUTH (OTP SMS)
# ========================
FIREBASE_PROJECT_ID=enbici-app
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@enbici-app.iam.gserviceaccount.com

# ========================
# GOOGLE MAPS API
# ========================
GOOGLE_MAPS_API_KEY=AIzaSy...
# Habilitar en Google Cloud Console:
# - Maps JavaScript API
# - Directions API
# - Distance Matrix API
# - Geocoding API
# - Places API

# ========================
# WOMPI (Pagos principal — Colombia)
# ========================
WOMPI_PUBLIC_KEY=pub_test_...
WOMPI_PRIVATE_KEY=prv_test_...
WOMPI_INTEGRITY_SECRET=tu_secreto_de_integridad
WOMPI_WEBHOOK_SECRET=tu_secreto_webhook
WOMPI_BASE_URL=https://sandbox.wompi.co/v1
# Producción: https://production.wompi.co/v1

# ========================
# BOLD (Pagos fallback — Colombia)
# ========================
BOLD_API_KEY=
BOLD_SECRET_KEY=
BOLD_BASE_URL=https://api.bold.co/online/link/v1

# ========================
# AWS (S3 + CloudFront + Rekognition)
# ========================
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=sa-east-1
AWS_S3_BUCKET=enbici-media-prod
AWS_CLOUDFRONT_URL=https://dxxxxxxxx.cloudfront.net

# ========================
# NOTIFICACIONES PUSH (FCM)
# ========================
FCM_SERVER_KEY=AAAA...
# Para Expo Push Notifications (alternativa sin FCM directo)
EXPO_ACCESS_TOKEN=

# ========================
# SEGURO SURA (por trayecto)
# ========================
SURA_API_URL=https://api.sura.com/v1
SURA_API_KEY=
SURA_POLICY_ID=

# ========================
# VERIFICACIÓN DOCUMENTOS COLOMBIA
# ========================
# Proveedor: Deqode o Semáforo Rojo
# Consultas: RUNT (SOAT + tecno-mecánica) + RNEC (antecedentes) + RUNT (licencia)
VERIFICATION_PROVIDER=deqode
DEQODE_API_URL=https://api.deqode.co/v1
DEQODE_API_KEY=

# ========================
# FLUTTER MOBILE (.env en mobile/.env — leído con flutter_dotenv)
# Estas variables van en mobile/.env (incluido en assets en pubspec.yaml)
# ========================
FLUTTER_API_URL=http://10.0.2.2:3000/api/v1
FLUTTER_SOCKET_URL=http://10.0.2.2:3000
FLUTTER_GOOGLE_MAPS_KEY=AIzaSy...
FLUTTER_WOMPI_PUBLIC_KEY=pub_test_...
FLUTTER_FIREBASE_API_KEY=AIzaSy...
FLUTTER_FIREBASE_AUTH_DOMAIN=enbici-app.firebaseapp.com
FLUTTER_FIREBASE_PROJECT_ID=enbici-app
# NOTA: google-services.json (Android) y GoogleService-Info.plist (iOS)
# se colocan en mobile/android/app/ y mobile/ios/Runner/ respectivamente
# NUNCA commitear esos archivos (están en .gitignore)

# ========================
# LOGGING Y MONITOREO
# ========================
LOG_LEVEL=debug
# Producción: info
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
